{
  "name": "allan-mcp-memory-code",
  "version": "1.3.2",
  "description": "Persistent knowledge graph memory for AI coding assistants. Runs 100% offline with Docker.",
  "main": "dist/index.js",
  "bin": {
    "allan-memory": "dist/cli.js",
    "allan-memory-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "build": "babel lib --out-dir dist --copy-files",
    "prepublishOnly": "npm run build",
    "postinstall": "npm run build 2>/dev/null || true",
    "start": "node dist/index.js",
    "start:dev": "node lib/index.js",
    "mcp": "node dist/mcp-server.js",
    "dev": "nodemon --exec 'node --require @babel/register' lib/index.js",
    "benchmark": "node benchmark.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "knowledge-graph",
    "falkordb",
    "memory",
    "mcp",
    "llm",
    "embeddings"
  ],
  "author": "",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "falkordb": "^6.1.0",
    "ignore": "^7.0.5",
    "openai": "^4.28.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/register": "^7.23.7",
    "nodemon": "^3.1.0"
  }
}
