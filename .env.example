# Server
PORT=19089
NODE_ENV=development
LOG_LEVEL=debug

# FalkorDB (Docker: localhost:6380)
FALKORDB_URI=redis://localhost:6380
FALKORDB_GRAPH_NAME=allan_memory

# ===========================================
# LLM Configuration - Choose ONE option below
# ===========================================

# Option 1: Full Offline (Ollama) - RECOMMENDED
# No API key required, runs entirely on local hardware
LLM_API_URL=http://localhost:11435/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b-instruct

# Option 2: Cloud (OpenRouter) - Requires API key
# LLM_API_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-your-key-here
# LLM_MODEL=qwen/qwen-2.5-7b-instruct

# ===========================================
# Embedder Configuration (Ollama)
# ===========================================
EMBEDDER_API_URL=http://localhost:11435/v1
EMBEDDER_API_KEY=ollama
EMBEDDER_MODEL=nomic-embed-text
EMBEDDER_DIMENSIONS=768

# Queue
SEMAPHORE_LIMIT=2
DEFAULT_GROUP_ID=main
