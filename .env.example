# Server
PORT=19089
NODE_ENV=development
LOG_LEVEL=debug

# FalkorDB (for local dev, use localhost:6380 when running docker dependencies)
FALKORDB_URI=redis://localhost:6380
FALKORDB_GRAPH_NAME=allan_memory

# LLM (OpenAI-compatible) - OpenRouter recommended
LLM_API_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-api-key
LLM_MODEL=qwen/qwen3-30b-a3b

# Embedder (OpenAI-compatible) - Ollama
# For local: http://localhost:11434/v1 or http://localhost:11435/v1 (docker)
EMBEDDER_API_URL=http://localhost:11435/v1
EMBEDDER_API_KEY=ollama
EMBEDDER_MODEL=nomic-embed-text
EMBEDDER_DIMENSIONS=768

# Queue
SEMAPHORE_LIMIT=2
DEFAULT_GROUP_ID=main
